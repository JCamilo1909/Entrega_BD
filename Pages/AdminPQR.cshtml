@page
@model SistemaRegistros.Pages.AdminPQRModel

@{
    var rol = HttpContext.Session.GetString("UsuarioRol");
}

<div class="navbar">
    <a class="navbar-brand" href="/">PRUEBA</a>
    <div class="navbar-links">
        <a href="/ProductosDisponibles">Productos</a>
        <a href="/FormularioPQR">PQRS</a>
        <a href="/HistorialCompras">Historial</a>
        @if (rol == "Admin")
        {
            <a href="/AdminPQR">Admin PQRS</a>
            <a href="/GestionProductos">Gestion Productos</a>
            <a href="/VisorBD">📊 Base de Datos</a>
        }
        <a href="/Login" style="color:#e94560;">Cerrar Sesión</a>
    </div>
</div>


<div class="contenedor">
    <h1 class="titulo-pagina">Gestión de PQRs</h1>

    @if (Model.listaPQRs.Count == 0)
    {
        <p style="color:#666; font-size:16px;">No hay PQRs registrados aún.</p>
    }
    else
    {
        <table class="tabla-historial">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tipo</th>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Mensaje</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pqr in Model.listaPQRs)
                {
                    <tr>
                        <td>@pqr.Id</td>
                        <td>@pqr.Tipo</td>
                        <td>@pqr.Nombre</td>
                        <td>@pqr.Correo</td>
                        <td>@pqr.Mensaje</td>
                        <td>
                            <form method="post">
                                <input type="hidden" name="id" value="@pqr.Id" />
                                <select name="estado" onchange="this.form.submit()"
                                        style="padding:5px; border-radius:5px; border:1px solid #ccc; font-size:13px;">
                                    <option value="Pendiente" selected="@(pqr.Estado == "Pendiente")">Pendiente</option>
                                    <option value="En proceso" selected="@(pqr.Estado == "En proceso")">En proceso</option>
                                    <option value="Resuelto" selected="@(pqr.Estado == "Resuelto")">Resuelto</option>
                                </select>
                            </form>
                        </td>
                        <td>@pqr.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a href="/AdminPQR?handler=Eliminar&amp;id=@pqr.Id" class="btn-accion btn-eliminar">
                                <span class="texto">ELIMINAR</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>