@page
@model SistemaRegistros.Pages.FormularioPQRModel
@{
    var rol = HttpContext.Session.GetString("UsuarioRol");
}

<div class="navbar">
    <a class="navbar-brand" href="/">🛒 TechStore</a>
    <div class="navbar-links">
        <a href="/ProductosDisponibles">Productos</a>
        <a href="/FormularioPQR">PQR</a>
        @if (rol == "Admin")
        {
            <a href="/HistorialCompras">Historial</a>
            <a href="/AdminPQR">Admin PQR</a>
        }
        <a href="/Login" style="color:#e94560;">Cerrar Sesión</a>
    </div>
</div>

<div class="contenedor">
    <h1 class="titulo-pagina">Peticiones, Quejas y Reclamos</h1>

    @if (Model.Enviado)
    {
        <div
            style="background:#e0f7e9; color:#1a7a3c; padding:15px 20px; border-radius:8px; margin-bottom:25px; font-size:15px;">
            ✅ Tu PQR fue enviado exitosamente. Te responderemos pronto.
        </div>
    }

    <div class="formulario-card">
        <form method="post">
            <div class="campo">
                <label>Tipo</label>
                <select name="PQR.Tipo"
                        style="width:100%; padding:12px 15px; border:2px solid #e0e0e0; border-radius:8px; font-size:14px;">
                    <option value="Peticion">Petición</option>
                    <option value="Queja">Queja</option>
                    <option value="Reclamo">Reclamo</option>
                </select>
            </div>
            <div class="campo">
                <label>Nombre</label>
                <input type="text" name="PQR.Nombre" placeholder="Tu nombre completo" required />
            </div>
            <div class="campo">
                <label>Correo</label>
                <input type="email" name="PQR.Correo" placeholder="tucorreo@email.com" required />
            </div>
            <div class="campo">
                <label>Mensaje</label>
                <textarea name="PQR.Mensaje" placeholder="Describe tu petición, queja o reclamo..." required
                          style="width:100%; padding:12px 15px; border:2px solid #e0e0e0; border-radius:8px; font-size:14px; height:120px; resize:vertical;"></textarea>
            </div>
            <button type="submit" class="btn-confirmar">📨 Enviar PQR</button>
        </form>
    </div>
</div>